<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="标签页"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/closeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关闭全部"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/addTab"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_add"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="fitCenter"
            android:imageTintList="?attr/colorPrimary" />

    </LinearLayout>

    <!-- Mode chip row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/normalChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_engine_chip_selected"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/privateChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_engine_chip"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Tab grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tabGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
